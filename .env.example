# Local Postgres (docker-compose in repo root) or any PostgreSQL URL.
# Vercel: add DATABASE_URL (and other secrets) in Project → Settings → Environment Variables.
# The default `npm run build` does not run migrations so the Vercel build succeeds without DB access.
# After the DB URL exists on Vercel, either set Build Command to `npm run build:production`
# or run migrations once from your machine: `npx prisma migrate deploy` with production DATABASE_URL.
DATABASE_URL="postgresql://fms:fms@localhost:5432/fms_booking"
# Supabase: the direct host db.<project>.supabase.co is often IPv6-only. If you get
# P1001 from your Mac, use Dashboard → Connect → Session pooler (URI). Host looks like
# aws-0-<region>.pooler.supabase.com:5432 with user postgres.<project-ref> — paste that
# whole string here (add ?sslmode=require if needed).
# Required for sessions, phone OTP HMAC, and registration JWTs. Min 16 characters; use a long random string in production.
# Never commit real values. Configure the same name everywhere you deploy:
# - Vercel: Project → Settings → Environment Variables → JWT_SECRET (all environments that run the app).
# - GitHub Actions: Repository → Settings → Secrets and variables → Actions → New repository secret → JWT_SECRET
#   (then reference as secrets.JWT_SECRET in workflow env).
JWT_SECRET="generate-a-long-random-string-at-least-16-chars"
# Production: public site URL (no path prefix), e.g. https://<project>.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Google Maps Embed API（選填）：「如何前往幻樂空間」頁面嵌入地圖。Google Cloud → Maps Embed API → 建立 API 金鑰；可設 HTTP referrer 限制。
# NEXT_PUBLIC_GOOGLE_MAPS_EMBED_API_KEY=your_embed_api_key
# Google Cloud OAuth 2.0 用戶端 ID（Web 應用程式）— 與 Maps Embed API「金鑰」不同；可用於需 OAuth 的 Google 地圖／登入等整合（依專案設定啟用對應 API）。
# NEXT_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_client_id.apps.googleusercontent.com

# Google 登入（用戶／管理員／登記頁預填電郵）：Google Cloud Console → OAuth 2.0 Client ID（網頁應用程式）。
# 授權重新導向 URI 須與實際網址完全一致：{origin}/api/v1/auth/google/callback（若有 NEXT_PUBLIC_BASE_PATH 請一併加上前綴）。
# 範圍僅使用 openid、email、profile；與「使用者 Google 日曆」OAuth 可為同一用戶端（多個重新導向 URI）或分開建立。
# NEXT_PUBLIC_GOOGLE_AUTH_CLIENT_ID=xxxx.apps.googleusercontent.com
# GOOGLE_AUTH_CLIENT_SECRET=xxxx
# 若伺服器端只設 GOOGLE_AUTH_CLIENT_ID（不帶 NEXT_PUBLIC_ 前綴），請與上方公開 ID 設為同一字串，否則登入按鈕不會顯示。
# Optional: Elfsight widget class for the D Festival block on the home page (e.g. elfsight-app-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx). Omit to hide that slot.
# NEXT_PUBLIC_ELFSIGHT_D_FESTIVAL_WIDGET_CLASS="elfsight-app-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
# Optional: override the built-in Elfsight Instagram feed on `/about-fantasia-music-space` (default: Untitled Instagram Feed 3).
# NEXT_PUBLIC_ELFSIGHT_FANTASIA_MUSIC_SPACE_WIDGET_CLASS="elfsight-app-353c18a5-3fca-44e6-88a7-17f4afd3d7ae"

# WebAuthn (Face ID / Touch ID / Windows Hello). API routes prefer the request `Origin` header, then Host — so preview URLs (*.vercel.app) work even if WEBAUTHN_* / NEXT_PUBLIC_APP_URL point at production.
# WEBAUTHN_ORIGIN / WEBAUTHN_RP_ID are fallbacks (or for www vs apex) only when RP ID is a valid suffix of the request hostname.
# Production behind a proxy or different public URL: set explicitly.
# WEBAUTHN_RP_ID=your.domain
# WEBAUTHN_ORIGIN=https://your.domain
# WEBAUTHN_RP_NAME="幻樂空間 FMS"

# `next dev` uses setting fallbacks when the DB is unreachable. `next start` (production)
# does not — set ALLOW_SETTINGS_FALLBACK=1 for local preview without Postgres, or fix DATABASE_URL.
# ALLOW_SETTINGS_FALLBACK=1
# Never use fallbacks on DB errors (always 500 if settings cannot be loaded).
# STRICT_SETTINGS_DB=1
# Registration confirmation emails (Resend). Get key: https://resend.com/api-keys
# Without RESEND_API_KEY, no real email is sent; in development the API still returns tempPassword.
# RESEND_API_KEY=re_xxxx
# From address: use a domain verified in Resend (resend.com/domains). Quote if the display name has spaces.
# EMAIL_FROM="幻樂空間 FMS <noreply@your-verified-domain.com>"

# When a user completes registration, send their full form snapshot to admin (Resend). Comma-separated.
# Default if unset: dfestival.office@gmail.com
# REGISTRATION_ADMIN_NOTIFY_EMAIL=dfestival.office@gmail.com

# When a user submits a booking request, send full details to admin (Resend). Comma-separated for multiple inboxes.
# Default if unset: dfestival.office@gmail.com
# BOOKING_ADMIN_NOTIFY_EMAIL=dfestival.office@gmail.com

# Booking confirmation email: Google Drive folder with venue / open-space reference (HTTPS).
# Default URL is set in code (src/lib/email/booking-submitted-mail.ts). Override only if the folder moves.
# BOOKING_SPACE_INFO_GOOGLE_DRIVE_URL=https://drive.google.com/drive/folders/1qhOhWbBcwYd95-J56z7nr1EzjSfuZU4A?usp=drive_link
# Optional: Sony 4K camcorder rental — Stripe Payment Link & usage guide (defaults are set in code).
# BOOKING_CAMERA_RENTAL_STRIPE_URL=https://buy.stripe.com/8x228sc1H4s13TReaPfAc0b
# BOOKING_CAMERA_USAGE_GOOGLE_DRIVE_URL=https://drive.google.com/drive/folders/1aQyRN2essexQXZzTfVV-lRhzy9FUNnkc?usp=sharing

# Contact page enquiry form: office notification recipients (Resend). Comma-separated.
# Default if unset: festival.office@gmail.com
# CONTACT_INQUIRY_ADMIN_EMAIL=festival.office@gmail.com

# Google Calendar: sync each new booking as one event (first slot start → last slot end, Asia/Hong_Kong).
# 1) Enable Calendar API in Google Cloud, create a service account, download JSON key.
# 2) Paste the entire JSON (single line or multiline) as the value below.
# 3) In Google Calendar (dfestival.office@gmail.com): Settings → Share with specific people → add the service account email with "Make changes to events".
# GOOGLE_CALENDAR_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Optional; defaults to dfestival.office@gmail.com
# GOOGLE_CALENDAR_ID=dfestival.office@gmail.com

# Google Calendar — member account page: sync merged booking blocks to the user’s own calendar (OAuth).
# 1) Google Cloud Console → APIs & Services → Credentials → Create OAuth client ID (Web application).
# 2) Authorized redirect URI must match exactly: {origin}/api/v1/account/google-calendar/oauth/callback
#    (include NEXT_PUBLIC_BASE_PATH prefix if you use one, e.g. https://example.com/app-prefix/api/v1/...).
# 3) Enable Google Calendar API for the same project. Scope: calendar.events (app requests offline access).
# GOOGLE_CALENDAR_OAUTH_CLIENT_ID=xxxx.apps.googleusercontent.com
# GOOGLE_CALENDAR_OAUTH_CLIENT_SECRET=xxxx

# Google Gemini（選填）— 帳戶頁頭像會按所選動物自動生成「動物彈琴」圖示。未設定時會使用內建插畫 SVG。
# GEMINI_API_KEY=

# 預約日曆活動說明欄（同步至使用者 Google 日曆時亦會附在活動內容）。門鎖密碼等敏感資料請只放在伺服器環境變數。
# VENUE_ADDRESS_ZH="幻樂空間地址（完整）"
# VENUE_RULES_URL="https://…"
# VENUE_DOOR_CODE="（例如門鎖密碼）"
# VENUE_ENTRY_NOTES_ZH="開門步驟、Wi‑Fi、垃圾回收等入場須知"

# SMS (Twilio) for registration phone verification. In NODE_ENV=development, codes are logged if these are unset.
# TWILIO_ACCOUNT_SID=ACxxxx
# TWILIO_AUTH_TOKEN=xxxx
# Use either a Twilio phone number in E.164, OR a Messaging Service SID (not both required):
# TWILIO_FROM_NUMBER=+852xxxxxxxx
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Re-paste values in Vercel if SMS fails silently: invisible Unicode after the number breaks the From field.
# Check credentials locally (no SMS sent): npm run verify:twilio  (uses .env.local / .env)

# Post-registration “six buttons” — optional overrides (HTTPS). Defaults live in src/lib/social-follow.ts (DEFAULT_SOCIAL_FOLLOW_URLS).
# NEXT_PUBLIC_SOCIAL_DFESTIVAL_IG_URL=https://…
# NEXT_PUBLIC_SOCIAL_DFESTIVAL_FB_URL=https://…
# NEXT_PUBLIC_SOCIAL_HK_FANTASIA_MGMT_IG_URL=https://…
# NEXT_PUBLIC_SOCIAL_HK_FANTASIA_MGMT_FB_URL=https://…
# NEXT_PUBLIC_SOCIAL_FANTASIA_SPACE_IG_URL=https://…
# NEXT_PUBLIC_SOCIAL_FANTASIA_SPACE_FB_URL=https://…
